# ─── Copy this to .env and fill in your values ────────────────────────────────

# Database
DB_NAME=jobfresh
DB_USER=jobfresh
DB_PASS=JobFresh@2025!          # Change this!
MYSQL_ROOT_PASSWORD=RootP@ss!   # Change this!

# Gmail SMTP (use App Password, not your real password)
# Enable 2FA → Google Account → App Passwords → Generate
MAIL_USER=your@gmail.com
MAIL_PASS=xxxx-xxxx-xxxx-xxxx

# JWT Secret (minimum 32 chars, use: openssl rand -hex 32)
JWT_SECRET=replace-with-openssl-rand-hex-32-output

# App
APP_URL=https://jobfresh.in

# Admin credentials (change after first login!)
ADMIN_EMAIL=admin@jobfresh.in
ADMIN_PASSWORD=Admin@123

# Extra CORS origins (comma-separated) — add your Vercel preview URL if needed
# e.g. CORS_EXTRA_ORIGINS=https://jobfresh-git-main-yourname.vercel.app
CORS_EXTRA_ORIGINS=
